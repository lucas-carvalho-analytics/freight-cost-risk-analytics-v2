## Production foundation example. Replace every placeholder before use.
APP_ENV=production
APP_NAME=freight_cost_risk_analytics
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

## Required: use real values only.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=freight_analytics

## Required for production: at least 32 characters and never commit the real value.
JWT_SECRET_KEY=replace-with-a-long-random-secret-with-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

LOG_LEVEL=info
WEB_CONCURRENCY=2

PRODUCTION_PORT=8080
