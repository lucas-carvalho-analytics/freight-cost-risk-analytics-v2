## Demo-only example. Replace placeholders before sharing a demo environment.
APP_ENV=demo
APP_NAME=freight_cost_risk_analytics
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=freight_analytics

## Required for demo: use a real secret with at least 32 characters.
JWT_SECRET_KEY=replace-with-a-long-random-secret-for-demo
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO

DEMO_PORT=8080
