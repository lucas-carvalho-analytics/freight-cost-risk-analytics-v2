## Development-only example. Do not reuse these values in demo/production.
APP_ENV=development
APP_NAME=freight_cost_risk_analytics
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1

## Required: set either DATABASE_URL or the POSTGRES_* values below.
DATABASE_URL=

## Required in every environment: use a real secret, never commit it.
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
WEB_CONCURRENCY=2

## Used when DATABASE_URL is empty.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=freight_analytics
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
